<script>
/* LOADER */
window.onload = function(){
    document.getElementById("loader").style.display = "none";

    if(localStorage.getItem("mode")=="light"){
        document.body.classList.add("light");
        document.querySelector(".fa-moon").classList.replace("fa-moon","fa-sun");
    }
}
/* SCROLL */
function scrollToGames(){
    document.getElementById("gamesSection").scrollIntoView();
}

/* SEARCH FILTER */
document.getElementById("searchInput").addEventListener("keyup", function(){
    let value = this.value.toLowerCase();
    document.querySelectorAll(".game-card").forEach(card => {
        card.style.display = card.innerText.toLowerCase().includes(value) ? "block" : "none";
    });
});

// load mode
if(localStorage.getItem("mode")=="light"){
    document.body.classList.add("light");
    document.querySelector(".fa-moon").classList.replace("fa-moon","fa-sun");
}

// toggle mode
function toggleMode(){
    document.body.classList.toggle("light");

    const icon = document.querySelector(".fa-moon, .fa-sun");

    if(document.body.classList.contains("light")){
        localStorage.setItem("mode","light");
        icon.classList.remove("fa-moon");
        icon.classList.add("fa-sun");
    } else {
        localStorage.setItem("mode","dark");
        icon.classList.remove("fa-sun");
        icon.classList.add("fa-moon");
    }
}

/* MUSIC TOGGLE */
let music = document.getElementById("bgMusic");
let isPlaying = false;

// user interaction pe hi play allow hota hai
document.body.addEventListener("click", () => {
    if(!isPlaying){
        music.play().then(()=>{
            isPlaying = true;
        }).catch(()=>{});
    }
}, { once: true });

document.addEventListener("visibilitychange", () => {
    if(!document.hidden && isPlaying){
        music.play();
    }
});
music.volume = 0.5; // 50% volume

// toggle button
function toggleMusic(){
    if(music.paused){
        music.play();
        isPlaying = true;
    } else {
        music.pause();
        isPlaying = false;
    }
}

/* FAVORITE TOGGLE */
document.querySelectorAll(".fav-btn").forEach(btn => {
    btn.addEventListener("click", function(){
        this.classList.toggle("active");
    });
});

function slideLeft(btn){
    const row = btn.parentElement.querySelector(".games-row");
    row.scrollBy({left:-900,behavior:"smooth"});
}

function slideRight(btn){
    const row = btn.parentElement.querySelector(".games-row");
    row.scrollBy({left:900,behavior:"smooth"});
}
//alert for user
function showLoginAlert(){
    alert("⚠️ Please Register or Login to Play Games!");
    window.location.href = "registration/login.php";
}

// games video
document.querySelectorAll(".game-card").forEach(card => {
    const video = card.querySelector(".game-video");

    card.addEventListener("mouseenter", () => {
        if(video){
            video.play().catch(()=>{});
        }
    });

    card.addEventListener("mouseleave", () => {
        if(video){
            video.pause();
            video.currentTime = 0;
        }
    });
});
</script>

</body>
